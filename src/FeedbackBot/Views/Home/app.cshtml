@model IReadOnlyList<FeedbackBot.Models.IssueContainer>

@{
    var appInfo = AppCatalog.Get(ViewData["AppName"]?.ToString());
    ViewData["Title"] = appInfo.Name;
}

<div class="container">
    <section>
        <div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div class="flex items-center gap-4">
                <img class="mt-1 h-10 w-10 shrink-0 object-contain" src="@Url.Content(appInfo.IconPath)" alt=""
                     aria-hidden="true" />
                <div>

                    <h2 class="text-2xl font-extrabold text-base-content">@appInfo.Name</h2>
                    <p class="mt-1 text-base text-base-content/70">Search existing issues or submit a new piece of
                        feedback.</p>
                    </div>
                </div>
                <a class="btn btn-primary" href="https://computing.caes.ucdavis.edu/documentation">View Documentation</a>
            </div>

            <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_minmax(360px,420px)]">
                <div class="space-y-4">
                    @if (ViewData["GitHubError"] != null)
                    {
                        <div class="alert alert-info rounded-md">
                            <span>@ViewData["GitHubError"]</span>
                        </div>
                    }

                    <partial name="SearchBarPartial" />

                    <section>
                        <div class="mt-6 mb-4 flex items-center justify-between gap-4">
                            <h3 class="text-2xl font-extrabold">Open issues</h3>
                            <span class="badge badge-primary">@Model.Count</span>
                        </div>
                        <partial name="DisplayIssuesPartial" model="Model" />
                    </section>
                </div>

                <partial name="NewIssuePartial" />
            </div>
        </section>
    </div>
