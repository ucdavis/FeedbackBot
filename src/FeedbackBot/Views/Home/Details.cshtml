@model FeedbackBot.Models.IssueDetailsViewModel

@{
    var appInfo = AppCatalog.Get(ViewData["AppName"]?.ToString());
    ViewData["Title"] = "Issue";
}

<div class="container">
    <section>
        <div class="mb-6">
            <a class="btn btn-outline btn-primary"
               href="@Url.Action("App", new { appName = ViewData["AppName"] })"><span
                class="transition group-hover:translate-x-1">&larr;</span> Back to
                @appInfo.Name Issues</a>
            </div>

            @if (Model.VoteMessage != null)
            {
                <div class="alert alert-info mb-6 rounded-md">
                    <span>@Model.VoteMessage</span>
                </div>
            }

            @if (ViewData["GitHubError"] != null)
            {
                <div class="alert alert-info mb-6 rounded-md">
                    <span>@ViewData["GitHubError"]</span>
                </div>
            }

            @if (Model.Issue != null)
            {
                <p class="text-sm font-bold mb-2 uppercase text-base-content/70">@appInfo.Name issue #@Model.Issue.Number
                </p>
                <article class="rounded-lg border border-main-border bg-base-100 p-6 shadow-sm">
                    <div class="flex flex-col gap-5 md:flex-row items-start md:justify-between">
                        <div class="min-w-0 flex-1">
                            <div class="flex items-center gap-4">

                                <div class="min-w-0">

                                    <h2 class="text-xl font-extrabold text-base-content">@Model.Issue.Title</h2>
                                    <p class="text-base-content/70">by @Model.Issue.Author</p>
                                </div>
                            </div>

                            <p class="mt-4 max-w-148 whitespace-pre-line leading-relaxed">@Model.Issue.Body</p>

                        </div>

                        <aside class="w-full md:w-56 md:self-end border-t-5 pt-3 border-primary/30">
                            <p class="text-2xl font-extrabold">@Model.Issue.NumOfVotes @(Model.Issue.NumOfVotesInt == 1 ? "vote"                        : "votes")</p>
                            <p class="mt-3 text-sm uppercase text-base-content/70">Upvoted by</p>
                            <p class="break-words text-base-content">@Model.Issue.StringOfVoters</p>

                            <form asp-action="Vote" asp-controller="Home" method="post" class="mt-4">
                                <input type="hidden" name="voteID" value="@Model.Issue.Number" />
                                <input type="hidden" name="appName" value="@ViewData["AppName"]" />
                                <button type="submit" class="btn btn-primary w-full rounded-md">@Model.Issue.VoteState</button>
                            </form>
                        </aside>
                    </div>
                </article>

                <section class="mt-6 rounded-lg border border-main-border bg-base-100 p-6 shadow-sm">
                    <h3 class="text-xl font-extrabold">Add a comment</h3>
                    <form asp-action="AddComment" asp-controller="Home" method="post" class="mt-4 space-y-4" data-new-comment-form>
                        <input type="hidden" name="voteID" value="@Model.Issue.Number" />
                        <input type="hidden" name="appName" value="@ViewData["AppName"]" />
                        <label class="sr-only" for="descriptionTextBoxComment">Comment</label>
                        <textarea class="textarea textarea-bordered min-h-36 w-full rounded-md bg-base-100"
                                  placeholder="Type your comment here (required)" id="descriptionTextBoxComment" name="comment" required data-comment-text></textarea>
                        <button class="btn btn-primary rounded-md" type="submit" data-comment-submit>Submit</button>
                    </form>

                    <script>
                        (() => {
                            const form = document.currentScript.previousElementSibling;
                            const commentInput = form?.querySelector("[data-comment-text]");
                            const submitButton = form?.querySelector("[data-comment-submit]");

                            const syncSubmitState = () => {
                                submitButton.disabled = commentInput.value.trim().length === 0;
                            };

                            if (!commentInput || !submitButton) {
                                return;
                            }

                            syncSubmitState();
                            commentInput.addEventListener("input", syncSubmitState);
                            commentInput.addEventListener("change", syncSubmitState);
                        })();
                    </script>
                </section>

                <section class="mt-6">
                    <div class="mb-4 flex items-center justify-between">
                        <h3 class="text-xl font-extrabold">@Model.Comments.Count @(Model.Comments.Count == 1 ? "Comment" :
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         "Comments")</h3>
                        </div>

                        @if (Model.Comments.Count == 0)
                        {
                            <div class="rounded-md border border-dashed border-main-border bg-base-100 p-8 text-center">
                                <p class="font-bold">No comments yet</p>
                                <p class="mt-1 text-sm text-base-content/70">Start the conversation with the form above.</p>
                            </div>
                        }
                        else
                        {
                            <div class="space-y-4">
                                @foreach (var comment in Model.Comments)
                                {
                                    <article class="rounded-md border border-main-border bg-base-100 p-5 shadow-sm">
                                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                                            <p class="font-bold">@comment.Author</p>
                                            <p class="text-sm text-base-content/60">@comment.CreateDate</p>
                                        </div>
                                        <p class="mt-4 whitespace-pre-line text-sm leading-6 text-base-content/80 max-w-5xl">@comment.Body
                                        </p>
                                    </article>
                                }
                            </div>
                        }
                    </section>
                }
            </section>
        </div>
