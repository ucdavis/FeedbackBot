@model FeedbackBot.Models.IssueDetailsViewModel

@{
    var appInfo = AppCatalog.Get(ViewData["AppName"]?.ToString());
    ViewData["Title"] = "Issue";
}

<div class="container">
    <section>
        <div class="mb-6">
            <a class="text-sm font-bold uppercase text-primary hover:underline"
               href="@Url.Action("App", new { appName = ViewData["AppName"] })">Back to @appInfo.Name</a>
        </div>

        @if (Model.VoteMessage != null)
        {
            <div class="alert alert-info mb-6 rounded-md">
                <span>@Model.VoteMessage</span>
            </div>
        }

        <article class="rounded-lg border border-main-border bg-base-100 p-6 shadow-sm">
            <div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
                <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-4">
                        <img class="h-10 w-10 shrink-0 object-contain" src="@Url.Content(appInfo.IconPath)" alt=""
                             aria-hidden="true" />
                        <div class="min-w-0">
                            <p class="text-sm font-bold uppercase text-primary">@appInfo.Name issue #@Model.Issue.Number
                            </p>
                            <h2 class="mt-2 text-3xl font-extrabold leading-tight">@Model.Issue.Title</h2>
                            <p class="mt-2 text-sm text-base-content/60">by @Model.Issue.Author</p>
                        </div>
                    </div>
                    <div class="mt-6 rounded-md bg-base-200 p-4">
                        <p class="whitespace-pre-line text-sm leading-6 text-base-content/80">@Model.Issue.Body</p>
                    </div>
                </div>

                <aside class="w-full rounded-md bg-base-200 p-4 md:w-56">
                    <p class="text-2xl font-extrabold">@Model.Issue.NumOfVotes</p>
                    <p class="text-sm font-semibold text-base-content/60">vote(s)</p>
                    <p class="mt-3 text-xs uppercase text-base-content/50">Upvoted by</p>
                    <p class="mt-1 break-words text-sm text-base-content/70">@Model.Issue.StringOfVoters</p>

                    <form asp-action="Vote" asp-controller="Home" method="post" class="mt-4">
                        <input type="hidden" name="voteID" value="@Model.Issue.Number" />
                        <input type="hidden" name="appName" value="@ViewData["AppName"]" />
                        <button type="submit" class="btn btn-primary w-full rounded-md">@Model.Issue.VoteState</button>
                    </form>
                </aside>
            </div>
        </article>

        <section class="mt-6 rounded-lg border border-main-border bg-base-100 p-6 shadow-sm">
            <h3 class="text-xl font-extrabold">Add a comment</h3>
            <form asp-action="AddComment" asp-controller="Home" method="post" class="mt-4 space-y-4">
                <input type="hidden" name="voteID" value="@Model.Issue.Number" />
                <input type="hidden" name="appName" value="@ViewData["AppName"]" />
                <label class="sr-only" for="descriptionTextBoxComment">Comment</label>
                <textarea class="textarea textarea-bordered min-h-36 w-full rounded-md bg-base-100"
                          placeholder="Type your comment here" id="descriptionTextBoxComment" name="comment"></textarea>
                <button class="btn btn-primary rounded-md" type="submit">Submit</button>
            </form>
        </section>

        <section class="mt-6">
            <div class="mb-4 flex items-center justify-between">
                <h3 class="text-xl font-extrabold">Comments</h3>
                <span class="badge badge-primary">@Model.Comments.Count</span>
            </div>

            @if (Model.Comments.Count == 0)
            {
                <div class="rounded-md border border-dashed border-main-border bg-base-100 p-8 text-center">
                    <p class="font-bold">No comments yet</p>
                    <p class="mt-1 text-sm text-base-content/70">Start the conversation with the form above.</p>
                </div>
            }
            else
            {
                <div class="space-y-4">
                    @foreach (var comment in Model.Comments)
                    {
                        <article class="rounded-md border border-main-border bg-base-100 p-5 shadow-sm">
                            <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                                <p class="font-bold">@comment.Author</p>
                                <p class="text-sm text-base-content/60">@comment.CreateDate</p>
                            </div>
                            <p class="mt-4 whitespace-pre-line text-sm leading-6 text-base-content/80">@comment.Body</p>
                        </article>
                    }
                </div>
            }
        </section>
    </section>
</div>
